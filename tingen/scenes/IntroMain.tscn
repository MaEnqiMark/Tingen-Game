[gd_scene format=3 uid="uid://difnomtq711u7"]

; Run-shell for the Klein's-bedroom vertical slice (spec §7). Mirrors Main.tscn but
; boots IntroRoom inside the persistent GameController + HUD shell, so examine (E),
; the investigation board (Tab), and the door transition produce visible results.
; Reuses src/GameController.gd, scenes/IntroRoom.tscn, and ui/HUD.tscn by reference;
; the project's default main_scene (Main.tscn) is unchanged.

[ext_resource type="Script" path="res://src/GameController.gd" id="1"]
[ext_resource type="PackedScene" path="res://scenes/IntroRoom.tscn" id="2"]
[ext_resource type="PackedScene" path="res://ui/HUD.tscn" id="3"]

[node name="IntroMain" type="Node2D"]
script = ExtResource("1")

[node name="World" type="Node2D" parent="."]

[node name="IntroRoom" parent="World" instance=ExtResource("2")]

[node name="UI" type="CanvasLayer" parent="."]

[node name="HUD" parent="UI" instance=ExtResource("3")]

[node name="PianoPortrait" parent="." unique_id=1235764244 instance=ExtResource("interactable")]
position = Vector2(448, 180)
thought = "她的画像挂在钢琴上方，纤尘不染。 (Her portrait hangs above the piano, kept free of dust — a shrine to someone long dead.)"
prompt_text = "Look at the portrait above the piano"
tint = Color(0.7, 0.66, 0.6, 0)
clue_id = "celeste_grief"

[node name="VialCabinet" parent="." unique_id=913718727 instance=ExtResource("interactable")]
position = Vector2(636, 185)
thought = "一排排标着日期的小瓶，暗红——是他自己的血。 (Rows of small dated vials of dark red — his own blood, drawn in careful measures.)"
prompt_text = "Examine the cabinet of vials"
tint = Color(0.7, 0.66, 0.6, 0)
clue_id = "stored_blood"

[node name="Worktable" parent="." unique_id=1090497293 instance=ExtResource("interactable")]
position = Vector2(269, 390)
thought = "蒸馏器、盐，还有一本摊开的禁忌图谱——“炼成生命”。 (Retorts, salts, and an open diagram of something forbidden: 'Alchemical Life.')"
prompt_text = "Study the workbench"
tint = Color(0.7, 0.66, 0.6, 0)
clue_id = "alchemical_life_ritual"

[node name="LettersDesk" parent="." unique_id=176757284 instance=ExtResource("interactable")]
position = Vector2(760, 430)
thought = "二十年的信，写给同一个人，每一封都记着又一次失败。 (Twenty years of letters to the same woman, each recording another failure.)"
prompt_text = "Read the scattered letters"
tint = Color(0.7, 0.66, 0.6, 0)
clue_id = "neils_obsession"

[node name="Door" parent="." unique_id=1446204110 instance=ExtResource("interactable")]
